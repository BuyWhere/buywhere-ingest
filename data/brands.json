{
  "kind": "brand",
  "description": "Hand-curated brand domains with known product-sitemap roots. Each entry is one (domain, sitemap_url[]) tuple that the sitemap worker fetches and walks for product-shaped <url><loc> entries. Migrated from scripts/buy30590-brand-sitemap-miner.mjs (Oracle workspace) on 2026-06-07 (BUY-34837). The original script scraped each product URL inline for JSON-LD structured data; the replacement is discovery-only and inserts the domain into the merchants table with source='sitemap_brand', leaving the actual catalog fetch to the existing scrape.shopify / scrape.woocommerce.deep / future lanes.",
  "source_label": "sitemap_brand",
  "entries": [
    {
      "domain": "nike.com",
      "source": "brand_nike",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://www.nike.com/sitemap_products.xml",
        "https://www.nike.com/sitemap.xml"
      ],
      "productPattern": "^https://www\\.nike\\.com/t/"
    },
