{
  "kind": "retailer",
  "description": "Hand-curated retailer domains with known product-sitemap roots and per-merchant product URL regexes. Migrated from scripts/buy30590-retailer-sitemap-miner.mjs (Oracle workspace) on 2026-06-07 (BUY-34837). The original script walked robots.txt to discover additional sitemap roots for some merchants (kohls, macys, homedepot, lowes, overstock, wayfair); the migration keeps the hand-curated seeds for now and skips the robots.txt walk — a future enhancement can add robots.txt discovery if the operators want broader coverage. The merchant-URL regexes are taken verbatim from the source script to preserve filter compatibility.",
  "source_label": "sitemap_retailer",
  "entries": [
    {
      "domain": "bestbuy.com",
      "source": "sitemap_bestbuy",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://sitemaps.bestbuy.com/sitemaps_pdp.xml",
        "https://www.bestbuy.com/sitemap.xml"
      ],
      "productPattern": "^https?://(www\\.)?bestbuy\\.com/site/[^/]+/\\d+\\.p"
    },
    {
      "domain": "walmart.com",
      "source": "sitemap_walmart",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://www.walmart.com/sitemap_tp_legacy.xml",
        "https://www.walmart.com/sitemap_tp_at.xml",
        "https://www.walmart.com/sitemap_tp_br.xml",
        "https://www.walmart.com/sitemap_tp_kp.xml",
        "https://www.walmart.com/sitemap_browse_fst.xml",
        "https://www.walmart.com/sitemap_brp_02.xml",
        "https://www.walmart.com/sitemap_brp_03.xml",
        "https://www.walmart.com/sitemap_brp_04.xml",
        "https://www.walmart.com/sitemap_brp_05.xml",
        "https://www.walmart.com/sitemap_brp_06.xml",
        "https://www.walmart.com/sitemap_brp_07.xml",
        "https://www.walmart.com/sitemap_brp_08.xml",
        "https://www.walmart.com/sitemap_brp_09.xml"
      ],
      "productPattern": "^https?://(www\\.)?walmart\\.com/ip/[^/]+/\\d{4,}"
    },
    {
      "domain": "target.com",
      "source": "sitemap_target",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://www.target.com/sitemap_pdp-index.xml.gz",
        "https://www.target.com/sitemap_taxonomy-categories-index.xml.gz"
      ],
      "productPattern": "^https?://(www\\.)?target\\.com/p/[^/]+/-/A-\\d{8,}"
    },
    {
      "domain": "wayfair.com",
      "source": "sitemap_wayfair",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://www.wayfair.com/seo-pdp-index.xml"
      ],
      "productPattern": "^https?://(www\\.)?wayfair\\.com/[a-z0-9-]+-w\\d+\\.html"
    },
    {
      "domain": "overstock.com",
      "source": "sitemap_overstock",
      "country": "US",
      "uaMode": "bot",
      "sitemaps": [
        "https://api.overstock.com/sitemaps/overstock-v3/us/sitemap.xml"
      ],
      "productPattern": "^https?://(www\\.)?overstock\\.com/products/\\d+"
    },
    {
      "domain": "kohls.com",
      "source": "sitemap_kohls",
      "country": "US",
      "uaMode": "desktop",
      "sitemaps": [
        "https://www.kohls.com/sitemap.xml"
      ],
      "productPattern": "^https?://(www\\.)?kohls\\.com/product/[^/]+"
    },
    {
      "domain": "macys.com",
      "source": "sitemap_macys",
      "country": "US",
      "uaMode": "desktop",
      "sitemaps": [
        "https://www.macys.com/dyn_img/sitemap/mcom_sitemapindex.xml"
      ],
      "productPattern": "^https?://(www\\.)?macys\\.com/shop/product/[^/]+"
    },
    {
      "domain": "homedepot.com",
      "source": "sitemap_homedepot",
      "country": "US",
      "uaMode": "desktop",
      "sitemaps": [
        "https://www.homedepot.com/sitemap.xml",
        "https://www.homedepot.com/sitemap/d/PIP_sitemap.xml"
      ],
      "productPattern": "^https?://(www\\.)?homedepot\\.com/p/[^/]+/\\d{6,}"
    },
    {
      "domain": "lowes.com",
      "source": "sitemap_lowes",
      "country": "US",
      "uaMode": "desktop",
      "sitemaps": [
        "https://www.lowes.com/sitemap.xml"
      ],
      "productPattern": "^https?://(www\\.)?lowes\\.com/pd/[^/]+/\\d{6,}"
    }
  ]
}
